{
  "name": "clearq-infrastructure",
  "version": "1.0.0",
  "description": "AWS Infrastructure Management Tools (Production Only)",
  "private": true,
  "type": "module",
  "scripts": {
    "s3:list": "npx tsx src/cli.ts s3 list",
    "s3:create": "npx tsx src/cli.ts s3 create",
    "s3:delete": "npx tsx src/cli.ts s3 delete",
    "containers:list": "npx tsx src/cli.ts containers list",
    "containers:create": "npx tsx src/cli.ts containers create",
    "containers:stop": "npx tsx src/cli.ts containers stop",
    "resources": "npx tsx src/cli.ts resources",
    "status": "npx tsx src/cli.ts status"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "^3.962.0",
    "@aws-sdk/client-ecs": "^3.962.0",
    "@aws-sdk/client-lambda": "^3.962.0",
    "@aws-sdk/client-s3": "^3.962.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
